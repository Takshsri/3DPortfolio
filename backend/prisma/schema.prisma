generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Project {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  tech        String
  github      String
  live        String
  image       String?
}